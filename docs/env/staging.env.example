# Staging env template for one-VPS Docker Compose deploy.
# Copy values to .env on the server and replace every change-me value.
# Never commit real tokens, passwords, or API keys.

APP_ENV=staging
APP_VERSION=staging
APP_HTTP_PORT=8080

POSTGRES_DB=hookah
POSTGRES_USER=hookah
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Must match POSTGRES_DB/POSTGRES_USER/POSTGRES_PASSWORD above.
# Example shape: jdbc:postgresql://postgres:5432/<POSTGRES_DB>
DB_JDBC_URL=jdbc:postgresql://postgres:5432/hookah
DB_USER=hookah
DB_PASSWORD=change-me
DB_MAX_POOL_SIZE=10
DB_CONNECTION_TIMEOUT_MS=30000

API_SESSION_JWT_SECRET=change-me
API_SESSION_TTL_SECONDS=3600
TELEGRAM_MINIAPP_INITDATA_MAX_AGE_SECONDS=300
TELEGRAM_MINIAPP_INITDATA_MAX_FUTURE_SKEW_SECONDS=30

TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_MODE=long_polling
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_WEBAPP_PUBLIC_URL=https://staging.hookahtootah.club/miniapp/
TELEGRAM_BOT_USERNAME=change-me
PLATFORM_OWNER_TELEGRAM_ID=change-me
# Legacy compatibility only. Leave empty when Telegram user id is the platform owner identity.
PLATFORM_OWNER_USER_ID=
TELEGRAM_LONG_POLLING_TIMEOUT_SECONDS=25
TELEGRAM_STAFF_CHAT_LINK_TTL_SECONDS=900
TELEGRAM_STAFF_CHAT_LINK_SECRET_PEPPER=change-me
TELEGRAM_REQUIRE_STAFF_CHAT_ADMIN=true

TELEGRAM_OUTBOX_POLL_INTERVAL_MS=500
TELEGRAM_OUTBOX_BATCH_SIZE=25
TELEGRAM_OUTBOX_VISIBILITY_TIMEOUT_SECONDS=30
TELEGRAM_OUTBOX_MAX_ATTEMPTS=10
TELEGRAM_OUTBOX_MAX_CONCURRENCY=4
TELEGRAM_OUTBOX_PER_CHAT_MIN_INTERVAL_MS=1000
TELEGRAM_OUTBOX_MIN_BACKOFF_SECONDS=1
TELEGRAM_OUTBOX_MAX_BACKOFF_SECONDS=60

MINIAPP_ENTRY_ENABLED=true
MINIAPP_DEV_SERVER_URL=
MINIAPP_STATIC_DIR=/app/miniapp
VITE_BACKEND_PUBLIC_URL=https://staging.hookahtootah.club
CORS_ALLOWED_HOSTS=https://staging.hookahtootah.club

GUEST_RATE_LIMIT_STAFF_CALL_MAX_REQUESTS=5
GUEST_RATE_LIMIT_STAFF_CALL_WINDOW_SECONDS=30
GUEST_RATE_LIMIT_ADD_BATCH_MAX_REQUESTS=5
GUEST_RATE_LIMIT_ADD_BATCH_WINDOW_SECONDS=10
GUEST_TABLE_SESSION_TTL_SECONDS=7200
GUEST_TABLE_SESSION_CLEANUP_INTERVAL_SECONDS=60

BOOKING_EXPIRY_WORKER_ENABLED=true
BOOKING_EXPIRY_INTERVAL_SECONDS=60
BOOKING_EXPIRY_BATCH_SIZE=50
BOOKING_REMINDER_WORKER_ENABLED=true
BOOKING_REMINDER_INTERVAL_SECONDS=60
BOOKING_REMINDER_BATCH_SIZE=50
VISIT_FEEDBACK_WORKER_ENABLED=true
VISIT_FEEDBACK_INTERVAL_SECONDS=60
VISIT_FEEDBACK_BATCH_SIZE=50

VENUE_STAFF_INVITE_TTL_SECONDS=604800
VENUE_STAFF_INVITE_MAX_TTL_SECONDS=2592000
VENUE_STAFF_INVITE_SECRET_PEPPER=change-me

BILLING_PROVIDER=fake
BILLING_WEBHOOK_SECRET=
BILLING_WEBHOOK_IP_ALLOWLIST=
BILLING_WEBHOOK_IP_ALLOWLIST_USE_X_FORWARDED_FOR=false
BILLING_GENERIC_CHECKOUT_BASE_URL=
BILLING_GENERIC_MERCHANT_ID=
BILLING_GENERIC_CHECKOUT_RETURN_URL=
BILLING_GENERIC_SIGNING_SECRET=
BILLING_GENERIC_SIGNATURE_HEADER=X-Billing-Signature
BILLING_SUBSCRIPTION_TIME_ZONE=Europe/Moscow
BILLING_SUBSCRIPTION_LEAD_DAYS=7
BILLING_SUBSCRIPTION_REMINDER_DAYS=3
BILLING_SUBSCRIPTION_GRACE_DAYS=3
BILLING_SUBSCRIPTION_INTERVAL_SECONDS=60

AI_ASSISTANT_ENABLED=false
AI_PROVIDER=fake
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=30000
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=1200
AI_RATE_LIMIT_PER_USER_PER_HOUR=20
AI_LOG_RAW_PROMPTS=false
AI_WRITE_ACTIONS_ENABLED=false
AI_SYSTEM_PROMPT_VERSION=staging
